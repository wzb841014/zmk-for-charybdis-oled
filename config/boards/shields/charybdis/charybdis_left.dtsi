#include "charybdis.dtsi"
/ {
	kscan0: kscan {
		compatible = "zmk,kscan-gpio-matrix";
		label = "KSCAN";
		row-gpios = <&pro_micro 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	};
};

// I2C for OLED on nice!nano
&pro_micro_i2c {
	status = "okay";
	sda-pin = <4>;    // P0.04
	scl-pin = <5>;    // P0.05
};
