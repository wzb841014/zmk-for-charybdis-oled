/* config/boards/arm/pinnacle_100/pinnacle_100.dtsi */
/* 
 * Pinnacle 100 Keyboard Board Device Tree Source Include
 * Based on nRF52840 DK / Nice!Nano architecture
 */

#include <nrf52840.dtsi>

/ {
    model = "Pinnacle 100 Keyboard";
    compatible = "pinnacle_100", "nordic,nrf52840";

    /* 选择内部高速振荡器 (HFXO) 如果外部有晶振，否则使用内部 RC */
    &clock {
        status = "okay";
    };

    /* 电源管理 */
    &power {
        status = "okay";
    };
};

/* 
 * I2C 总线配置 (假设 IC27 触摸芯片连接在 I2C0)
 * 请根据实际原理图修改 SDA/SCL 引脚
 */
&i2c0 {
    status = "okay";
    clock-frequency = <400000>; /* 400kHz */
    
    /* 
     * IC27 电容触摸传感器节点 
     * 标签名: ic27_touch (这就是你在 overlay 中要引用的名字)
     */
    ic27_touch: touch@27 {
        compatible = "semtech,sx1280"; /* 注意：请替换为实际的驱动兼容字符串，例如 "onsemi,ncs2200" 或 "zmk,cap-sensor" */
        reg = <0x27>;                  /* I2C 地址 0x27 */
        status = "disabled";           /* 默认禁用，由 Shield Overlay 启用 */
        
        /* 中断引脚配置 (请根据原理图修改 GPIO 端口和引脚号) */
        interrupt-gpios = <&gpio0 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;
        
        /* 其他可能的属性，取决于具体驱动 */
        // zmk,read-delay-ms = <5>;
    };
};

/* 
 * SPI 总线配置 (如果你还有 GC9A01A 屏幕，通常也在 SPI 上)
 * 假设屏幕连接在 SPI0
 */
&spi0 {
    status = "okay";
    spi-max-frequency = <8000000>; /* 8MHz */
    
    /* 示例：GC9A01A 屏幕节点 (如果也在这个板子上定义) */
    /* 
    gc9a01a_display: gc9a01a@0 {
        compatible = "gc9a01a-display";
        reg = <0>;
        status = "disabled";
        reset-gpios = <&gpio0 5 GPIO_ACTIVE_LOW>;
        dc-gpios = <&gpio0 6 GPIO_ACTIVE_HIGH>;
        spi-max-frequency = <8000000>;
    };
    */
};

/* 
 * GPIO 按键矩阵 (KSCAN) 配置示例
 * 分体键盘通常需要配置 matrix 扫描
 */
/*
&kscan {
    status = "okay";
    // ... 矩阵配置 ...
};
*/

